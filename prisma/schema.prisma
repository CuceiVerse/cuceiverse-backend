generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  siiauCode    String   @unique @map("siiau_code")
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships  ProjectMember[]

  @@map("users")
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  DONE
}

enum ProjectRole {
  PROJECT_MANAGER
  UX_UI_DESIGNER
  BACKEND_DEVELOPER
  FULLSTACK_DEVELOPER
  QA_TESTER
  PROFESOR
}

enum PuntoInteresTipo {
  FOOD
  MEDICAL
  BATHROOM
  CAFETERIA
  GENERAL_SERVICES
  AUDITORIUM
  BANK
  LIBRARY
  INFO
  ADMIN
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  members     ProjectMember[]

  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      ProjectRole
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model PuntoInteres {
  id                 String           @id @default(uuid())
  nombre             String
  tipo               PuntoInteresTipo
  coordenadaXGrid    Int              @map("coordenada_x_grid")
  coordenadaYGrid    Int              @map("coordenada_y_grid")
  descripcion        String?
  activo             Boolean          @default(true)
  edificioReferencia String?          @map("edificio_referencia")
  prioridadVisual    Int              @default(0) @map("prioridad_visual")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([tipo, activo])
  @@index([edificioReferencia])
  @@index([prioridadVisual])
  @@map("puntos_interes")
}
